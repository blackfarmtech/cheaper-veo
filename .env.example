# --- Database (Postgres / Supabase or Neon) ---
# Supabase: use TRANSACTION-MODE pooler (port 6543) on DATABASE_URL with the
# two query flags below — without them, serverless invocations exhaust the
# session-mode pool (max ~15 connections) and queries fail with
# "MaxClientsInSessionMode" under any real traffic.
#   - pgbouncer=true → disables prepared statements (incompatible with txn mode)
#   - connection_limit=1 → one connection per Prisma client; Fluid Compute reuses
DATABASE_URL="postgres://postgres.<ref>:<pass>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Session-mode (port 5432) — required by Prisma for migrations.
DIRECT_URL="postgres://postgres.<ref>:<pass>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Better Auth ---
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Set to "1" only after enabling Stripe Tax in the Dashboard (Settings → Tax)
# and registering for tax in your jurisdictions. Otherwise checkout creation
# will fail with a "Stripe Tax has not been activated" error.
STRIPE_AUTOMATIC_TAX="0"

# --- Provider backend (NestJS gemini-videos) ---
# Accepts with or without /api at the end — the client normalizes.
GERAEW_PROVIDER_URL="http://localhost:8012/api"
GERAEW_PROVIDER_KEY="x-api-key-of-the-nestjs-backend"

# --- Supabase Storage (S3-compatible) ---
# 1. Supabase Dashboard → Storage → create bucket "videos" (Public).
# 2. Storage → S3 Connection → create Access Key and copy below.
# 3. Endpoint follows the pattern https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_ENDPOINT="https://<project-ref>.storage.supabase.co/storage/v1/s3"
SUPABASE_S3_REGION="us-west-1"
SUPABASE_S3_ACCESS_KEY_ID=""
SUPABASE_S3_SECRET_ACCESS_KEY=""
SUPABASE_VIDEOS_BUCKET="videos"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Email (Resend) ---
# 1. Create an API key at https://resend.com/api-keys
# 2. Verify your sending domain at https://resend.com/domains
#    (in dev you can use the shared "onboarding@resend.dev" sender — leave EMAIL_FROM unset)
RESEND_API_KEY=""
EMAIL_FROM="Cheaper Veo <noreply@cheaperveo.com>"
EMAIL_REPLY_TO="support@cheaperveo.com"
